# Copy to .env and fill in real values for production
NODE_ENV=production
PORT=3000

# Generate secrets with:
# node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-this-with-a-64-char-random-string
CONTENT_TOKEN_SECRET=replace-this-with-a-different-64-char-random-string
CAPTCHA_SECRET=replace-this-with-another-64-char-random-string

# Comma-separated account/user ids allowed to open /admin/security.
ADMIN_USER_IDS=

# Optional: allow admin access by username instead of id, useful in local dev.
ADMIN_USERNAMES=

# Default is 2. Keep explicit in production so the limit is obvious.
MAX_DEVICES_PER_USER=2

# Behind one reverse proxy/CDN, keep 1. Use false only when directly exposed.
TRUST_PROXY=1

# MySQL connection — used by lib/mysql.js for all persistent data.
# The `npm run db:init` and `npm run db:migrate` scripts both read these vars.
#
# Local dev (mysql running on this machine):
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your_password
# MYSQL_DATABASE=prompt_vault
# MYSQL_CONNECTION_LIMIT=10
#
# TiDB Cloud (preferred for Vercel deployment — free tier 5 GiB):
#   1. Sign up at https://tidbcloud.com
#   2. Create a "Starter" cluster, region Singapore or Tokyo
#   3. In Cluster → Connect, copy the "Standard Connection" string
#   4. Paste it here as MYSQL_URL
# MYSQL_URL=mysql://xxxxxx.root:your_password@gateway01.ap-southeast-1.prod.aws.tidbcloud.com:4000/prompt_vault?ssl=true
#
# You can mix either form. If both are set, MYSQL_URL wins.
